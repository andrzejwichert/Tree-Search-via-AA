Cell[CellGroupData[{
Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"Evaluate8PuzzleStats", "[", 
    RowBox[{"m_Integer", ":", "4"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
      "neighbors", ",", "multiplier", ",", "initialState", ",", "finalStates",
        ",", "finalValues", ",", "totalLeaves", ",", "mode", ",", "mean"}], 
      "}"}], ",", 
     RowBox[{"(*", 
      RowBox[{
      "1.", " ", "Define", " ", "the", " ", "3", "x3", " ", "grid", " ", 
       "graph", " ", "layout", " ", "for", " ", "the", " ", "blank", " ", 
       "tile", " ", "positions", " ", 
       RowBox[{"(", 
        RowBox[{"1", " ", "to", " ", "9"}], ")"}]}], "*)"}], 
     RowBox[{
      RowBox[{"neighbors", "=", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"1", "->", 
          RowBox[{"{", 
           RowBox[{"2", ",", "4"}], "}"}]}], ",", 
         RowBox[{"2", "->", 
          RowBox[{"{", 
           RowBox[{"1", ",", "3", ",", "5"}], "}"}]}], ",", 
         RowBox[{"3", "->", 
          RowBox[{"{", 
           RowBox[{"2", ",", "6"}], "}"}]}], ",", 
         RowBox[{"4", "->", 
          RowBox[{"{", 
           RowBox[{"1", ",", "5", ",", "7"}], "}"}]}], ",", 
         RowBox[{"5", "->", 
          RowBox[{"{", 
           RowBox[{"2", ",", "4", ",", "6", ",", "8"}], "}"}]}], ",", 
         RowBox[{"6", "->", 
          RowBox[{"{", 
           RowBox[{"3", ",", "5", ",", "9"}], "}"}]}], ",", 
         RowBox[{"7", "->", 
          RowBox[{"{", 
           RowBox[{"4", ",", "8"}], "}"}]}], ",", 
         RowBox[{"8", "->", 
          RowBox[{"{", 
           RowBox[{"5", ",", "7", ",", "9"}], "}"}]}], ",", 
         RowBox[{"9", "->", 
          RowBox[{"{", 
           RowBox[{"6", ",", "8"}], "}"}]}]}], "|>"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "2.", " ", "Define", " ", "path", " ", "multipliers", " ", "based", " ",
         "on", " ", "the", " ", "branching", " ", "rules"}], "*)"}], 
      RowBox[{
       RowBox[{"multiplier", "[", "pos_", "]"}], ":=", 
       RowBox[{"Which", "[", 
        RowBox[{
         RowBox[{"MemberQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"1", ",", "3", ",", "7", ",", "9"}], "}"}], ",", "pos"}], 
          "]"}], ",", "2", ",", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"Corners", ":", 
            RowBox[{"2", " ", "moves"}]}], "->", 
           RowBox[{"multiply", " ", "by", " ", "2"}]}], "*)"}], 
         RowBox[{"MemberQ", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"2", ",", "4", ",", "6", ",", "8"}], "}"}], ",", "pos"}], 
          "]"}], ",", "3", ",", 
         RowBox[{"(*", 
          RowBox[{
           RowBox[{"Edges", ":", 
            RowBox[{"3", " ", "moves"}]}], "->", 
           RowBox[{"multiply", " ", "by", " ", "4"}]}], "*)"}], 
         RowBox[{"pos", "==", "5"}], ",", "4"}], "                     ", 
        RowBox[{"(*", 
         RowBox[{
          RowBox[{"Center", ":", 
           RowBox[{"4", " ", "moves"}]}], "->", 
          RowBox[{"multiply", " ", "by", " ", "4"}]}], "*)"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{"3.", " ", "Initial", " ", 
         RowBox[{"State", ":", 
          RowBox[{"position", " ", "3", " ", 
           RowBox[{"(", 
            RowBox[{"starting", " ", "corner"}], ")"}]}]}]}], ",", 
        RowBox[{"value", "=", "1"}], ",", 
        RowBox[{
         RowBox[{"path", " ", "count"}], "=", "1"}]}], "*)"}], 
      RowBox[{"initialState", "=", 
       RowBox[{"<|", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"3", ",", "1"}], "}"}], "->", "1"}], "|>"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
        RowBox[{
        "4.", " ", "Propagate", " ", "the", " ", "state", " ", "layer"}], "-",
         "by", "-", 
        RowBox[{
        "layer", " ", "up", " ", "to", " ", "depth", " ", "m", " ", "using", " ",
          "state", " ", "aggregation"}]}], "*)"}], 
      RowBox[{"finalStates", "=", 
       RowBox[{"Nest", "[", 
        RowBox[{
         RowBox[{"Function", "[", 
          RowBox[{"states", ",", 
           RowBox[{"Merge", "[", 
            RowBox[{
             RowBox[{"Flatten", "[", 
              RowBox[{"KeyValueMap", "[", 
               RowBox[{
                RowBox[{"Function", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"key", ",", "count"}], "}"}], ",", 
                  RowBox[{"With", "[", 
                   RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"pos", "=", 
                    RowBox[{"key", "[", 
                    RowBox[{"[", "1", "]"}], "]"}]}], ",", 
                    RowBox[{"val", "=", 
                    RowBox[{"key", "[", 
                    RowBox[{"[", "2", "]"}], "]"}]}]}], "}"}], ",", 
                    RowBox[{"Table", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{"n", ",", 
                    RowBox[{"val", "*", 
                    RowBox[{"multiplier", "[", "pos", "]"}]}]}], "}"}], "->", 
                    "count"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"n", ",", 
                    RowBox[{"neighbors", "[", "pos", "]"}]}], "}"}]}], 
                    "]"}]}], "]"}]}], "]"}], ",", "states"}], "]"}], "]"}], ",",
              "Total"}], "]"}]}], "]"}], ",", "initialState", ",", "m"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{
       "5.", " ", "Collapse", " ", "grid", " ", "positions", " ", "to", " ", 
        "isolate", " ", "final", " ", "values", " ", "and", " ", "their", " ",
         "exact", " ", "frequencies"}], "*)"}], 
      RowBox[{"finalValues", "=", 
       RowBox[{"KeySort", "[", 
        RowBox[{"Merge", "[", 
         RowBox[{
          RowBox[{"KeyValueMap", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"#1", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "->", "#2"}], "&"}], ",", 
            "finalStates"}], "]"}], ",", "Total"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"6.", " ", "Calculate", " ", "Statistical", " ", "Means"}], 
       "*)"}], 
      RowBox[{"totalLeaves", "=", 
       RowBox[{"Total", "[", "finalValues", "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"mode", "=", 
       RowBox[{"Keys", "[", 
        RowBox[{"Select", "[", 
         RowBox[{"finalValues", ",", 
          RowBox[{
           RowBox[{"#", "==", 
            RowBox[{"Max", "[", "finalValues", "]"}]}], "&"}]}], "]"}], 
        "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"mean", "=", 
       RowBox[{"N", "[", 
        RowBox[{
         RowBox[{"Total", "[", 
          RowBox[{"KeyValueMap", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"#1", "*", "#2"}], "&"}], ",", "finalValues"}], "]"}], 
          "]"}], "/", "totalLeaves"}], "]"}]}], ";", "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"7.", " ", "Format", " ", "and", " ", "Print", " ", "Report"}],
        "*)"}], 
      RowBox[{"Print", "[", 
       RowBox[{"TextGrid", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"\"\<Statistical Metric\>\"", ",", "\"\<Value\>\""}], 
            "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"\"\<Target Depth (m)\>\"", ",", "m"}], "}"}], ",", 
           RowBox[{"{", 
            
            RowBox[{"\"\<Total Leaf Nodes Generated\>\"", ",", 
             "totalLeaves"}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"\"\<Distinct Values Found\>\"", ",", 
             RowBox[{"Length", "[", "finalValues", "]"}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"\"\<Statistical Mode(s)\>\"", ",", "mode"}], "}"}], ",", 
           
           RowBox[{"{", 
            RowBox[{"\"\<Expected Value (Mean)\>\"", ",", "mean"}], "}"}]}], 
          "}"}], ",", 
         RowBox[{"Frame", "->", "All"}], ",", 
         RowBox[{"Background", "->", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"LightGray", ",", "None"}], "}"}], ",", 
            RowBox[{"{", 
             RowBox[{"LightBlue", ",", "None"}], "}"}]}], "}"}]}]}], "]"}], 
       "]"}], ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", "\"\<\\nExact Frequency Distribution:\>\"", "]"}],
       ";", "\[IndentingNewLine]", 
      RowBox[{"Print", "[", 
       RowBox[{"Dataset", "[", "finalValues", "]"}], "]"}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"(*", 
       RowBox[{"8.", " ", "Visual", " ", "Distribution", " ", "Graph"}], 
       "*)"}], 
      RowBox[{"BarChart", "[", 
       RowBox[{"finalValues", ",", 
        RowBox[{"ChartLabels", "->", "Automatic"}], ",", 
        RowBox[{"PlotLabel", "->", 
         RowBox[{"\"\<Leaf Value Probability Distribution (m = \>\"", "<>", 
          RowBox[{"ToString", "[", "m", "]"}], "<>", "\"\<)\>\""}]}], ",", 
        RowBox[{"AxesLabel", "->", 
         RowBox[{"{", 
          
          RowBox[{"\"\<Final Path Value\>\"", 
           ",", "\"\<Frequency Count\>\""}], "}"}]}], ",", 
        RowBox[{"ImageSize", "->", "Large"}]}], "]"}]}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{"Evaluate8PuzzleStats", "[", "10", "]"}]}], "Input",
